rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function activeAccount(userId) {
      return signedIn() && request.auth.uid == userId &&
        (!exists(/databases/$(database)/documents/deletedUsers/$(userId)) ||
          get(/databases/$(database)/documents/deletedUsers/$(userId)).data.expiresAt <= request.time);
    }

    function ownsProfessionalAccount(doctorId) {
      return activeAccount(request.auth.uid) &&
        exists(/databases/$(database)/documents/professionalAccounts/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/professionalAccounts/$(request.auth.uid)).data.doctorId == doctorId &&
        get(/databases/$(database)/documents/professionalAccounts/$(request.auth.uid)).data.status == "active";
    }

    function userProfileFields() {
      return ["email", "cidade", "convenio", "tipo_atendimento", "idioma", "acessibilidade", "consent_preferences", "consent_at", "created_at", "updated_at"];
    }

    function serverOwnedUserTimestamps() {
      return (!request.resource.data.diff(resource.data).affectedKeys().hasAny(["updated_at"]) || (request.resource.data.updated_at is timestamp && request.resource.data.updated_at == request.time)) &&
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(["consent_at"]) || (request.resource.data.consent_at is timestamp && request.resource.data.consent_at == request.time));
    }

    function consentTransitionAllowed() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["consent_preferences"]) ||
        !resource.data.keys().hasAll(["consent_preferences"]) ||
        resource.data.consent_preferences != true ||
        request.resource.data.consent_preferences == true;
    }

    function consentGrantTimestampValid() {
      return !request.resource.data.keys().hasAll(["consent_preferences"]) ||
        request.resource.data.consent_preferences != true ||
        (resource.data.keys().hasAll(["consent_preferences"]) && resource.data.consent_preferences == true) ||
        (request.resource.data.consent_at is timestamp && request.resource.data.consent_at == request.time);
    }

    function hasHealthSearchConsent(userId) {
      return activeAccount(userId) &&
        exists(/databases/$(database)/documents/users/$(userId)) &&
        get(/databases/$(database)/documents/users/$(userId)).data.consent_preferences == true;
    }

    // ─── Public directory: doctors ──────────────────────────────
    // Anyone can read the doctor directory (no auth required).
    // Writes are disabled — managed by admin / Cloud Functions only.
    match /doctors/{doctorId} {
      allow read: if false;
      allow write: if false;
      // Note: Admin SDK bypasses security rules. Admin writes use the
      // service account, not user SDK. This rule blocks user SDK writes only.
    }

    // Public projection only. Private doctor records stay server-only.
    match /publicDoctors/{doctorId} {
      allow read: if resource.data.published == true && resource.data.publicReadSafe == true;
      allow write: if false;
    }

    // ─── Public directory: specialties ──────────────────────────
    // Anyone can read the list of medical specialties.
    match /specialties/{specialtyId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── User data — only the owner can access ──────────────────
    // A signed-in user may read and write only their own document.
    match /users/{userId} {
      allow read: if activeAccount(userId);
      allow create: if activeAccount(userId) && request.resource.data.keys().hasOnly(userProfileFields()) && request.resource.data.email == request.auth.token.email && request.resource.data.created_at is timestamp && request.resource.data.created_at == request.time && (!request.resource.data.keys().hasAll(["consent_preferences"]) || request.resource.data.consent_preferences != true || (request.resource.data.consent_at is timestamp && request.resource.data.consent_at == request.time));
      allow update: if activeAccount(userId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userProfileFields()) && request.resource.data.email == request.auth.token.email && (!resource.data.keys().hasAll(["created_at"]) || request.resource.data.created_at == resource.data.created_at) && serverOwnedUserTimestamps() && consentTransitionAllowed() && consentGrantTimestampValid();
      // Deletion must start at Firebase Auth so onUserDelete can erase all owned subcollections.
      allow delete: if false;

      // Interests subcollection — same ownership rule.
      match /interests/{interestId} {
        allow read: if activeAccount(userId);
        allow create, update: if false;
        allow delete: if activeAccount(userId);
      }

      // Search events are written by the app and consumed/deleted by
      // Cloud Functions. Raw search data is sensitive, so user reads
      // are blocked — the CF processes and deletes these immediately.
      match /search_events/{eventId} {
        allow read: if false; // sensitive — CF processes and deletes immediately
        allow create: if activeAccount(userId) &&
          hasHealthSearchConsent(userId) &&
          request.resource.data.keys().hasOnly(["query", "timestamp"]) &&
          request.resource.data.query is string &&
          request.resource.data.query.size() <= 240 &&
          request.resource.data.timestamp is timestamp;
        allow update, delete: if false; // only Cloud Functions delete these
      }

      // Account synchronization is callable-only. A visitor keeps saved
      // items only in local storage; account sync occurs after explicit login.
      match /favorites/{doctorId} {
        allow read, write: if false;
      }
      match /savedSearches/{searchId} {
        allow read, write: if false;
      }
    }

    // ─── Appointment orchestration ─────────────────────────────
    // All mutations happen inside callable Cloud Functions. Patients
    // may read only their own requests. Professionals receive a
    // purpose-built server DTO instead of the raw patient UID.
    match /appointments/{appointmentId} {
      allow read: if signedIn() && activeAccount(request.auth.uid) && resource.data.patientUid == request.auth.uid;
      allow write: if false;

      match /audit/{eventId} {
        allow read: if ownsProfessionalAccount(get(/databases/$(database)/documents/appointments/$(appointmentId)).data.doctorId);
        allow write: if false;
      }
    }

    // A professional account maps one authenticated doctor to one
    // claimed Profile médico. Claim/review is server-only.
    match /professionalAccounts/{userId} {
      allow read: if activeAccount(userId);
      allow write: if false;
    }

    // Account-deletion tombstones are server-only. They block stale ID
    // tokens from recreating data until the scheduled residual sweep.
    match /deletedUsers/{userId} {
      allow read, write: if false;
    }

    // Availability, OAuth connection data, idempotency, outbox and
    // guest access tokens are never client-readable or client-writable.
    match /calendarAvailability/{doctorId} {
      allow read, write: if false;
    }
    match /calendarConnections/{doctorId} {
      allow read, write: if false;
    }
    match /calendarOutbox/{outboxId} {
      allow read, write: if false;
    }
    match /appointmentIdempotency/{key} {
      allow read, write: if false;
    }
    match /appointmentRateLimits/{key} {
      allow read, write: if false;
    }
    match /appointmentAccess/{tokenHash} {
      allow read, write: if false;
    }

    // Medário Pro data never accepts direct client mutations. Dashboard
    // data is served by ownership-checked callables until a dedicated
    // Firebase adapter is introduced.
    match /profileChangeRequests/{requestId} {
      allow read, write: if false;
      match /audit/{eventId} {
        allow read, write: if false;
      }
    }
    match /professionalLeadMetrics/{doctorId} {
      allow read, write: if false;
    }
    match /professionalLeads/{leadId} {
      allow read, write: if false;
    }
    match /notificationPreferences/{userId} {
      allow read, write: if false;
    }
    match /notificationEndpoints/{endpointId} {
      allow read, write: if false;
    }
    match /notificationOutbox/{notificationId} {
      allow read, write: if false;
    }
    match /notificationDeliveryAttempts/{attemptId} {
      allow read, write: if false;
    }
  }
}
